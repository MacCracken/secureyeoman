# SecureYeoman — Complete Environment Reference
#
# This file documents EVERY available environment variable.
# Most have sensible defaults — only SECUREYEOMAN_ADMIN_PASSWORD is required.
#
# For a minimal config, see .env.example (production) or .env.dev.example (dev).

# ═════════════════════════════════════════════════════════════
# SECURITY KEYS
# Only ADMIN_PASSWORD is required. All cryptographic keys are
# auto-generated at first boot, stored in SecretsManager, and
# rotation-managed (90-day cycle). Setting a key externally
# disables auto-rotation for that key.
# ═════════════════════════════════════════════════════════════
SECUREYEOMAN_ADMIN_PASSWORD=change-me-to-a-random-32ch-pass
# SECUREYEOMAN_SIGNING_KEY=                    # Optional — auto-generated. Set for compliance (e.g. FIPS).
# SECUREYEOMAN_TOKEN_SECRET=                   # Optional — auto-generated. JWT signing key.
# SECUREYEOMAN_ENCRYPTION_KEY=                 # Optional — auto-generated. At-rest encryption key.
# SECUREYEOMAN_WEBHOOK_SECRET=                 # Optional — auto-generated. HMAC-SHA256 for CI/CD webhooks.

# ═════════════════════════════════════════════════════════════
# AI PROVIDERS
# Server starts without keys; chat disabled until configured.
# Set here or add later via Administration > Secrets > AI Provider Keys.
# ═════════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-...                 # console.anthropic.com
# OPENAI_API_KEY=sk-...                        # platform.openai.com/api-keys
# GOOGLE_GENERATIVE_AI_API_KEY=...             # aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...                           # Alternative / fallback for Google providers
# OPENCODE_API_KEY=...                         # opencode.ai/settings (BYOK model)
# XAI_API_KEY=                                 # console.x.ai (Grok models)
# XAI_BASE_URL=                                # Optional: custom X.AI base URL
# DEEPSEEK_API_KEY=                            # platform.deepseek.com
# DEEPSEEK_BASE_URL=                           # Optional: custom DeepSeek base URL
# MISTRAL_API_KEY=                             # console.mistral.ai
# MISTRAL_BASE_URL=                            # Optional: custom Mistral base URL
# GROQ_API_KEY=                                # console.groq.com (LPU inference)
# OPENROUTER_API_KEY=                          # openrouter.ai (multi-provider router)
# OPENROUTER_BASE_URL=                         # Optional: custom OpenRouter base URL
# LETTA_API_KEY=                               # app.letta.com — stateful agent platform
# LETTA_BASE_URL=                              # Optional: self-hosted Letta server URL
# LETTA_AGENT_ID=                              # Optional: reuse a pre-existing Letta agent
# LETTA_LOCAL=true                             # Optional: use http://localhost:8283

# Local inference — no API key needed
# OLLAMA_HOST=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LOCALAI_BASE_URL=http://localhost:8080/v1

# ═════════════════════════════════════════════════════════════
# DATABASE
# Embedded PostgreSQL auto-generates a password on first boot
# and persists it to /var/lib/postgresql/.pg_password.
# Set POSTGRES_PASSWORD only when using an external database.
# ═════════════════════════════════════════════════════════════
# POSTGRES_PASSWORD=                           # Auto-generated for embedded PG; required for external PG
# DATABASE_HOST=                               # Unset or localhost = embedded PG; set to external host to skip
# DATABASE_USER=secureyeoman                   # Default: secureyeoman
# DATABASE_NAME=secureyeoman                   # Default: secureyeoman

# ═════════════════════════════════════════════════════════════
# TEST DATABASE (Vitest)
# All values default to match the main DB config.
# Create once: createdb -U secureyeoman secureyeoman_test
# ═════════════════════════════════════════════════════════════
# TEST_DB_NAME=secureyeoman_test               # Default: secureyeoman_test
# TEST_DB_USER=secureyeoman                    # Default: secureyeoman (falls back to DATABASE_USER)
# TEST_DB_PASSWORD=secureyeoman_dev            # Default: secureyeoman_dev (falls back to POSTGRES_PASSWORD)
# TEST_DB_HOST=localhost                       # Default: localhost (falls back to DATABASE_HOST)
# TEST_DB_PORT=5432                            # Default: 5432

# ═════════════════════════════════════════════════════════════
# SERVER
# ═════════════════════════════════════════════════════════════
# SECUREYEOMAN_PORT=18789                      # HTTP listen port
# SECUREYEOMAN_HOST=0.0.0.0                    # Bind address (0.0.0.0 for Docker, 127.0.0.1 for local)
# SECUREYEOMAN_LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal
# SECUREYEOMAN_EXTERNAL_URL=                   # Public-facing URL (for OAuth redirects, webhook URLs)

# ═════════════════════════════════════════════════════════════
# TLS / HTTPS
# Unified vars shared across SY, Agnostic, and AGNOS containers.
# See docs/guides/tls-certificates.md for full setup guide.
# ═════════════════════════════════════════════════════════════
# TLS_ENABLED=false                            # Enable Caddy TLS reverse proxy
# TLS_CERT_PATH=/app/certs/certificate.txt     # Path inside Docker container
# TLS_KEY_PATH=/app/certs/private_key.txt      # Omit both for auto ACME
# TLS_DOMAIN=secureyeoman.example.com          # Domain for cert/ACME
# TLS_PORT=443                                 # TLS listen port
#
# Legacy vars (still supported; unified vars take precedence):
# SECUREYEOMAN_TLS_ENABLED=false
# SECUREYEOMAN_TLS_CERT_PATH=
# SECUREYEOMAN_TLS_KEY_PATH=
#
# SECUREYEOMAN_ALLOW_REMOTE_ACCESS=false       # Allow non-LAN access (pair with TLS)
# SECUREYEOMAN_CORS_ORIGINS=                   # Comma-separated allowed origins

# ═════════════════════════════════════════════════════════════
# DASHBOARD & GATEWAY URLs
# Only needed when running the Vite dev server over HTTPS.
# Not used in production builds — use a reverse proxy instead.
# ═════════════════════════════════════════════════════════════
# VITE_GATEWAY_URL=http://core:18789           # Change to https:// when TLS is enabled
# VITE_ALLOWED_HOSTS=dev.yourdomain.com        # Comma-separated hostnames
# VITE_TLS_CERT=certs/certificate.txt          # Path relative to repo root
# VITE_TLS_KEY=certs/private_key.txt
# VITE_STORYBOOK_URL=http://localhost:6006     # Storybook dev server URL

# ═════════════════════════════════════════════════════════════
# MCP SERVICE
# Enable with: docker compose --profile mcp up
# No manual token needed — MCP self-mints a service JWT.
# ═════════════════════════════════════════════════════════════
# MCP_ENABLED=false                            # Enable MCP sidecar
# MCP_PORT=3001                                # MCP listen port
# MCP_HOST=127.0.0.1                           # MCP bind address
# MCP_TRANSPORT=streamable-http                # streamable-http | sse | stdio
# MCP_AUTO_REGISTER=true                       # Auto-register tools on startup
# MCP_CORE_URL=http://127.0.0.1:18789         # Core API URL (for internal calls)
# MCP_EXPOSE_FILESYSTEM=false                  # Enable filesystem tools
# MCP_ALLOWED_PATHS=                           # Comma-separated allowed base paths (required when filesystem=true)
# MCP_RATE_LIMIT_PER_TOOL=30                   # Max calls per tool per minute
# MCP_LOG_LEVEL=info                           # MCP log level

# ─── MCP Tool Toggles ────────────────────────────────────
# MCP_EXPOSE_BULLSHIFT_TOOLS=false             # BullShift trading tools
# MCP_EXPOSE_PHOTISNADI_TOOLS=false            # Photisnadi task/ritual tools
# MCP_EXPOSE_AGNOS_TOOLS=false                 # AGNOS runtime tools (20+)
# MCP_EXPOSE_AGNOSTIC_TOOLS=false              # Agnostic QA tools (25+)
# MCP_EXPOSE_SECURITY_TOOLS=false              # Kali security toolkit
# MCP_EXPOSE_QUICKBOOKS_TOOLS=false            # QuickBooks Online tools
# MCP_EXPOSE_SYNAPSE_TOOLS=false              # Synapse LLM controller tools

# ─── MCP — Kali Security Toolkit ─────────────────────────
# Run `secureyeoman security setup` to provision the Docker container first.
# MCP_SECURITY_TOOLS_MODE=native               # native | docker-exec
# MCP_SECURITY_TOOLS_CONTAINER=kali-sy-toolkit # docker-exec mode only
# MCP_ALLOWED_TARGETS=                         # Comma-separated CIDRs/hostnames
# SHODAN_API_KEY=                              # Optional — enables sec_shodan tool

# ─── MCP — QuickBooks Online ─────────────────────────────
# Run `secureyeoman mcp-quickbooks enable` for setup instructions.
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REALM_ID=
# QUICKBOOKS_REFRESH_TOKEN=
# QUICKBOOKS_ENVIRONMENT=sandbox               # sandbox | production

# ═════════════════════════════════════════════════════════════
# ECOSYSTEM SERVICES
# API keys are auto-generated on-demand when you enable a service
# via Dashboard > Connections > MCP > Ecosystem Services.
# ═════════════════════════════════════════════════════════════

# ─── AGNOS Runtime ────────────────────────────────────────
# Enable with: docker compose --profile agnos up
# AGNOS_GATEWAY_URL=http://agnosticos:8088     # LLM Gateway (OpenAI-compatible)
# AGNOS_RUNTIME_URL=http://agnosticos:8090     # Agent Runtime
# AGNOS_GATEWAY_API_KEY=                       # Optional — auto-generated on service enable
# AGNOS_RUNTIME_API_KEY=                       # Optional — auto-generated on service enable

# ─── Agnostic QA Platform ────────────────────────────────
# Enable with: docker compose --profile agnostic up
# AGNOSTIC_URL=http://127.0.0.1:8000           # Agnostic QA platform URL
# AGNOSTIC_API_KEY=                            # Optional — auto-generated on service enable
# AGNOSTIC_WEBHOOK_SECRET=                     # Optional — auto-generated on service enable
# CREDENTIAL_PROVISIONING_ENABLED=false        # Push LLM creds to Agnostic at runtime
# AGNOSTIC_HOOKS_ENABLED=false                 # Auto-trigger QA on agent events

# ─── BullShift Trading ───────────────────────────────────
# BULLSHIFT_API_URL=http://bullshift:8787      # Default: http://localhost:8787
# ALPACA_API_KEY=                              # Required for BullShift to start
# ALPACA_SECRET_KEY=                           # Required for BullShift to start

# ─── Photisnadi Task/Ritual ──────────────────────────────
# Supabase is optional — tools work without it.
# PHOTISNADI_SUPABASE_URL=                     # Supabase project URL
# PHOTISNADI_SUPABASE_KEY=                     # Supabase service role key
# PHOTISNADI_USER_ID=                          # Photis user ID

# ─── CI/CD Webhooks ──────────────────────────────────────
# Provider-specific tokens for verifying inbound webhook signatures.
# SECUREYEOMAN_WEBHOOK_SECRET is auto-generated (see Security Keys above).
# JENKINS_WEBHOOK_TOKEN=                       # Static token for Jenkins X-Jenkins-Crumb header
# GITLAB_WEBHOOK_TOKEN=                        # Static token for GitLab X-Gitlab-Token header
# NORTHFLANK_WEBHOOK_SECRET=                   # HMAC-SHA256 key for Northflank X-Northflank-Signature

# ═════════════════════════════════════════════════════════════
# OAUTH CONNECTIONS
# Enables social login on Dashboard > Connections.
# ═════════════════════════════════════════════════════════════
# OAUTH_REDIRECT_BASE_URL=                     # Base URL for redirect URIs (defaults to SECUREYEOMAN_EXTERNAL_URL)
# GITHUB_OAUTH_CLIENT_ID=                      # https://github.com/settings/developers
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=                      # https://console.cloud.google.com/apis/credentials
# GOOGLE_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_CLIENT_ID=                       # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GMAIL_OAUTH_CLIENT_SECRET=                   # Defaults to GOOGLE_OAUTH_CLIENT_SECRET
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID=             # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=                # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# ═════════════════════════════════════════════════════════════
# COMMUNITY SKILLS
# ═════════════════════════════════════════════════════════════
# COMMUNITY_REPO_PATH=/usr/share/secureyeoman/community-repo  # Docker default (set via ENV in Dockerfile)
# COMMUNITY_GIT_URL=https://github.com/MacCracken/secureyeoman-community-repo
#   # Requires: secureyeoman policy set allowCommunityGitFetch true

# ═════════════════════════════════════════════════════════════
# INTEGRATION PLUGINS
# ═════════════════════════════════════════════════════════════
# INTEGRATION_PLUGIN_DIR=/opt/secureyeoman/plugins  # Drop .mjs/.js files to auto-load custom adapters

# ═════════════════════════════════════════════════════════════
# RATE LIMITING
# ═════════════════════════════════════════════════════════════
# SECUREYEOMAN_AUTH_LOGIN_MAX_ATTEMPTS=5       # Max login attempts per window
# SECUREYEOMAN_AUTH_LOGIN_WINDOW_MS=900000     # Window length in ms (default: 15 min)

# ═════════════════════════════════════════════════════════════
# REDIS (optional — enables distributed rate limiting)
# ═════════════════════════════════════════════════════════════
# REDIS_URL=redis://localhost:6379

# ═════════════════════════════════════════════════════════════
# LICENSE ENFORCEMENT
# ═════════════════════════════════════════════════════════════
# SECUREYEOMAN_LICENSE_ENFORCEMENT=false       # Set true to enforce enterprise feature gates (402 for unlicensed)

# SecureYeoman Environment Configuration
# Copy this file to .env and fill in your values.
# See docs/configuration.md for full reference.

# ─────────────────────────────────────────────────────────
# Security Keys  (required — generate your own, 32+ chars)
# ─────────────────────────────────────────────────────────
SECUREYEOMAN_SIGNING_KEY=change-me-to-a-random-32char-key
SECUREYEOMAN_TOKEN_SECRET=change-me-to-a-random-32ch-tokn
SECUREYEOMAN_ENCRYPTION_KEY=change-me-to-a-random-32ch-ekey
SECUREYEOMAN_ADMIN_PASSWORD=change-me-to-a-random-32ch-pass

# ─────────────────────────────────────────────────────────
# AI Providers  (optional — server starts without keys; chat disabled until configured)
# Set here or add later via Administration > Secrets > AI Provider Keys
# ─────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...         # console.anthropic.com
# OPENAI_API_KEY=sk-...               # platform.openai.com/api-keys
# GOOGLE_GENERATIVE_AI_API_KEY=...    # aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...                  # Alternative / fallback for Google providers
# OPENCODE_API_KEY=...                # opencode.ai/settings (BYOK model)
# XAI_API_KEY=                        # console.x.ai  (Grok models)
# XAI_BASE_URL=                       # Optional: override x.ai base URL
# DEEPSEEK_API_KEY=                   # platform.deepseek.com
# DEEPSEEK_BASE_URL=                  # Optional: override DeepSeek base URL
# MISTRAL_API_KEY=                    # console.mistral.ai
# MISTRAL_BASE_URL=                   # Optional: override Mistral base URL
# GROQ_API_KEY=                       # console.groq.com (LPU inference)
# OPENROUTER_API_KEY=                 # openrouter.ai (multi-provider router)
# OPENROUTER_BASE_URL=                # Optional: custom OpenRouter base URL
# LETTA_API_KEY=                      # app.letta.com — stateful agent platform
# LETTA_BASE_URL=                     # Optional: self-hosted Letta server URL
# LETTA_AGENT_ID=                     # Optional: reuse a pre-existing Letta agent
# LETTA_LOCAL=true                    # Optional: use http://localhost:8283

# Local inference — no API key needed
# OLLAMA_HOST=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LOCALAI_BASE_URL=http://localhost:8080/v1

# ─────────────────────────────────────────────────────────
# Database  (defaults match docker-compose.yml)
# ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=secureyeoman_dev
# DATABASE_HOST=localhost
# DATABASE_USER=secureyeoman
# DATABASE_NAME=secureyeoman

# ─────────────────────────────────────────────────────────
# Server  (optional — defaults shown)
# ─────────────────────────────────────────────────────────
# SECUREYEOMAN_PORT=18789
# SECUREYEOMAN_HOST=0.0.0.0
# SECUREYEOMAN_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────
# Dashboard TLS & Allowed Hosts  (dev server only)
# Only needed when running the Vite dev server over HTTPS.
# Not used in production builds — use a reverse proxy instead.
# Paths are relative to the repo root.
# ─────────────────────────────────────────────────────────
# VITE_ALLOWED_HOSTS=dev.yourdomain.com
# VITE_TLS_CERT=certs/certificate.txt
# VITE_TLS_KEY=certs/private_key.txt

# ─────────────────────────────────────────────────────────
# MCP Service  (optional — enable with: docker compose --profile mcp up)
# No manual token needed — MCP self-mints a service JWT using SECUREYEOMAN_TOKEN_SECRET.
# ─────────────────────────────────────────────────────────
# MCP_ENABLED=true
# MCP_PORT=3001
# MCP_HOST=127.0.0.1
# MCP_TRANSPORT=streamable-http        # streamable-http | sse | stdio
# MCP_AUTO_REGISTER=true
# MCP_CORE_URL=http://127.0.0.1:18789
# MCP_EXPOSE_FILESYSTEM=false
# MCP_ALLOWED_PATHS=
# MCP_RATE_LIMIT_PER_TOOL=30
# MCP_LOG_LEVEL=info

# ─────────────────────────────────────────────────────────
# MCP — Kali Security Toolkit  (optional — requires MCP service)
# Run `secureyeoman security setup` to provision the Docker container.
# See `secureyeoman security --help` and docs/adr/089-*.md for full guide.
# ─────────────────────────────────────────────────────────
# MCP_EXPOSE_SECURITY_TOOLS=false
# MCP_SECURITY_TOOLS_MODE=native               # native | docker-exec
# MCP_SECURITY_TOOLS_CONTAINER=kali-sy-toolkit # docker-exec mode only
# MCP_ALLOWED_TARGETS=                         # comma-separated CIDRs/hostnames, e.g. 10.10.10.0/24,ctf.example.com
# SHODAN_API_KEY=                              # optional — enables sec_shodan tool

# ─────────────────────────────────────────────────────────
# MCP — QuickBooks Online  (optional — requires MCP service)
# Run `secureyeoman mcp-quickbooks enable` for setup instructions.
# QUICKBOOKS_ENVIRONMENT defaults to sandbox; set to production when ready.
# ─────────────────────────────────────────────────────────
# MCP_EXPOSE_QUICKBOOKS_TOOLS=false
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REALM_ID=
# QUICKBOOKS_REFRESH_TOKEN=
# QUICKBOOKS_ENVIRONMENT=sandbox               # sandbox | production

# ─────────────────────────────────────────────────────────
# OAuth Connections  (optional — enables social login on Dashboard > Connections)
# ─────────────────────────────────────────────────────────
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_CLIENT_ID=              # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GMAIL_OAUTH_CLIENT_SECRET=          # Defaults to GOOGLE_OAUTH_CLIENT_SECRET
# GOOGLE_CALENDAR_OAUTH_CLIENT_ID=    # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GOOGLE_CALENDAR_OAUTH_CLIENT_SECRET=
# GOOGLE_DRIVE_OAUTH_CLIENT_ID=       # Defaults to GOOGLE_OAUTH_CLIENT_ID
# GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────
# Community Skills
# Docker default path: /usr/share/secureyeoman/community-skills (set via ENV in Dockerfile)
# Git URL fetch requires: secureyeoman policy set allowCommunityGitFetch true
# COMMUNITY_GIT_URL is optional — defaults to https://github.com/MacCracken/secureyeoman-community-skills
# ─────────────────────────────────────────────────────────
# COMMUNITY_REPO_PATH=/usr/share/secureyeoman/community-skills
# COMMUNITY_GIT_URL=https://github.com/MacCracken/secureyeoman-community-skills

# ─────────────────────────────────────────────────────────
# Integration Plugins  (optional — drop .mjs/.js files to auto-load custom adapters)
# ─────────────────────────────────────────────────────────
# INTEGRATION_PLUGIN_DIR=/opt/secureyeoman/plugins

# ─────────────────────────────────────────────────────────
# Rate Limiting  (optional — defaults shown are production values)
# ─────────────────────────────────────────────────────────
# SECUREYEOMAN_AUTH_LOGIN_MAX_ATTEMPTS=5      # Max login attempts per window (default: 5)
# SECUREYEOMAN_AUTH_LOGIN_WINDOW_MS=900000    # Window length in ms (default: 900000 = 15 min)

# ─────────────────────────────────────────────────────────
# Redis  (optional — enables distributed rate limiting)
# ─────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────
# License Enforcement (Phase 106)
# ─────────────────────────────────────────────────────────
# SECUREYEOMAN_LICENSE_ENFORCEMENT=false  # Set to true to enforce enterprise feature gates (402 for unlicensed)

# SecureYeoman — Minimal Configuration
#
# Only ADMIN_PASSWORD is required. Everything else has sensible defaults.
# For the full list of options see .env.expanded.example.
#
# Quick start:
#   cp .env.example .env
#   # Edit SECUREYEOMAN_ADMIN_PASSWORD below
#   docker compose up -d

# ─── Required ──────────────────────────────────────────────
SECUREYEOMAN_ADMIN_PASSWORD=change-me-to-a-random-32ch-pass

# ─── Database ──────────────────────────────────────────────
# Embedded PostgreSQL auto-generates a password on first boot.
# Only set POSTGRES_PASSWORD when using an external database.
# POSTGRES_PASSWORD=
# DATABASE_HOST=                                 # Set to external host to skip embedded PG

# ─── AI Providers (optional) ──────────────────────────────
# Server starts without keys; chat disabled until configured.
# Set here or add later via Administration > Secrets > AI Provider Keys.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── TLS / HTTPS (optional) ──────────────────────────────
# See docs/guides/tls-certificates.md for setup.
# TLS_ENABLED=true
# TLS_CERT_PATH=/app/certs/certificate.txt
# TLS_KEY_PATH=/app/certs/private_key_decrypted.txt
# TLS_DOMAIN=secureyeoman.example.com

# ─── Everything else ──────────────────────────────────────
# All cryptographic keys, webhook secrets, and integration API keys
# are auto-generated and rotation-managed when not set.
# See .env.expanded.example for the complete reference.

{
  "name": "secureyeoman",
  "version": "2026.3.12-2",
  "description": "SecureYeoman — Secure, local-first AI assistant",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @secureyeoman/shared && npm run build -w @secureyeoman/mcp && npm run build -w @secureyeoman/core -w @secureyeoman/dashboard",
    "dev": "npm run dev --workspace=@secureyeoman/core",
    "dev:dashboard": "npm run dev --workspace=@secureyeoman/dashboard",
    "dev:mcp": "npm run dev --workspace=@secureyeoman/mcp",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npx vitest run --project core:e2e",
    "test:e2e:fe": "npx playwright test --config packages/dashboard/playwright.config.ts",
    "bench": "npm run bench --workspace=@secureyeoman/core",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint packages/",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=8192' eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/dashboard/tsconfig.json",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "security:audit": "npm audit --audit-level=moderate",
    "release-notes": "npx tsx scripts/generate-release-notes.ts",
    "version:set": "bash scripts/set-version.sh",
    "build:binary": "bash scripts/build-binary.sh",
    "build:binary:dev": "bash scripts/build-binary.sh --dev",
    "dev:desktop": "npm run dev --workspace=@secureyeoman/desktop",
    "build:desktop": "npm run build --workspace=@secureyeoman/desktop",
    "db:create-test": "docker compose exec postgres createdb -U secureyeoman secureyeoman_test || true",
    "prepare": "git config core.hooksPath .githooks"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MacCracken/secureyeoman.git"
  },
  "license": "AGPL-3.0-only",
  "author": "SecureYeoman Project Contributors",
  "keywords": [
    "ai",
    "agent",
    "security",
    "autonomous",
    "claude",
    "assistant"
  ],
  "overrides": {
    "@discordjs/rest": {
      "undici": "6.23.0"
    },
    "discord.js": {
      "undici": "6.23.0"
    },
    "dompurify": "3.3.2",
    "nanoid": "5.1.6",
    "@excalidraw/mermaid-to-excalidraw": {
      "mermaid": "10.9.5"
    },
    "serialize-javascript": ">=7.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "dompurify": "3.3.2"
  }
}

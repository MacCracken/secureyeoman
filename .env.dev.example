# SecureYeoman — Developer Environment
#
# Copy this file to .env and fill in your values.
# For production configuration see .env.example.
#
# Quick start:
#   docker compose up -d   # starts Postgres on localhost:5432
#   npm install
#   cp .env.dev.example .env
#   npm run dev

# ─────────────────────────────────────────────────────────
# Security Keys  (any 32+ char string works for dev)
# ─────────────────────────────────────────────────────────
SECUREYEOMAN_SIGNING_KEY=dev-signing-key-change-me-in-production!!
SECUREYEOMAN_TOKEN_SECRET=dev-token-secret-change-me-in-production!!
SECUREYEOMAN_ENCRYPTION_KEY=dev-encryption-key-change-me-in-prod!!
SECUREYEOMAN_ADMIN_PASSWORD=dev-admin-password-change-in-production

# ─────────────────────────────────────────────────────────
# AI Providers  (optional — server starts without keys; chat disabled until configured)
# Set here or add later via Administration > Secrets > AI Provider Keys
# ─────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...         # console.anthropic.com
# OPENAI_API_KEY=sk-...               # platform.openai.com/api-keys
# GOOGLE_GENERATIVE_AI_API_KEY=...    # aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...                  # Alternative / fallback for Google providers
# OPENCODE_API_KEY=...                # opencode.ai/settings (BYOK model)
# XAI_API_KEY=                        # console.x.ai  (Grok models)
# XAI_BASE_URL=                       # Optional: override x.ai base URL
# DEEPSEEK_API_KEY=                   # platform.deepseek.com
# DEEPSEEK_BASE_URL=                  # Optional: override DeepSeek base URL
# MISTRAL_API_KEY=                    # console.mistral.ai
# MISTRAL_BASE_URL=                   # Optional: override Mistral base URL
# GROQ_API_KEY=                       # console.groq.com (LPU inference)
# OPENROUTER_API_KEY=                 # openrouter.ai (multi-provider router)
# OPENROUTER_BASE_URL=                # Optional: custom OpenRouter base URL
# LETTA_API_KEY=                      # app.letta.com — stateful agent platform
# LETTA_BASE_URL=                     # Optional: self-hosted Letta server URL
# LETTA_AGENT_ID=                     # Optional: reuse a pre-existing Letta agent
# LETTA_LOCAL=true                    # Optional: use http://localhost:8283

# Local inference — no API key needed
# OLLAMA_HOST=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LOCALAI_BASE_URL=http://localhost:8080/v1

# ─────────────────────────────────────────────────────────
# Database  (defaults match docker-compose.yml — no changes needed with Docker Compose)
# ─────────────────────────────────────────────────────────
POSTGRES_PASSWORD=secureyeoman_dev
# DATABASE_HOST=localhost
# DATABASE_USER=secureyeoman
# DATABASE_NAME=secureyeoman

# ─────────────────────────────────────────────────────────
# Test Database  (Vitest)
# Create once: createdb -U secureyeoman secureyeoman_test
# Migrations run automatically on test start.
# ─────────────────────────────────────────────────────────
# TEST_DB_NAME=secureyeoman_test
# TEST_DB_USER=secureyeoman
# TEST_DB_PASSWORD=secureyeoman_dev
# TEST_DB_HOST=localhost
# TEST_DB_PORT=5432

# ─────────────────────────────────────────────────────────
# Server  (optional — defaults shown)
# ─────────────────────────────────────────────────────────
# SECUREYEOMAN_PORT=18789
# SECUREYEOMAN_HOST=127.0.0.1
# SECUREYEOMAN_LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────
# TLS / HTTPS  (optional — all commented out = plain HTTP)
# Place cert files in certs/ (gitignored). See docs/guides/tls-certificates.md.
#
# Unified TLS vars (shared across SY, Agnostic, AGNOS):
# ─────────────────────────────────────────────────────────
# TLS_ENABLED=true                                         # enable Caddy TLS reverse proxy
# TLS_CERT_PATH=/app/certs/certificate.txt                 # path inside Docker container
# TLS_KEY_PATH=/app/certs/private_key_decrypted.txt        # omit both for auto ACME
# TLS_DOMAIN=secureyeoman.example.com                      # domain for cert/ACME
# TLS_PORT=443                                             # TLS listen port (default: 443)
#
# Legacy vars (still supported, unified vars take precedence):
# SECUREYEOMAN_TLS_ENABLED=true
# SECUREYEOMAN_TLS_CERT_PATH=/app/certs/certificate.txt
# SECUREYEOMAN_TLS_KEY_PATH=/app/certs/private_key_decrypted.txt
#
# SECUREYEOMAN_ALLOW_REMOTE_ACCESS=true                    # allow non-LAN access (pair with TLS)
# SECUREYEOMAN_CORS_ORIGINS=https://dev.yourdomain.com:3000

# ─────────────────────────────────────────────────────────
# Dashboard & MCP gateway URLs  (match TLS setting above)
# ─────────────────────────────────────────────────────────
# VITE_GATEWAY_URL=http://core:18789    # change to https:// when TLS is enabled
# MCP_CORE_URL=http://core:18789        # change to https:// when TLS is enabled
# VITE_ALLOWED_HOSTS=dev.yourdomain.com
# VITE_TLS_CERT=certs/certificate.txt   # path relative to repo root
# VITE_TLS_KEY=certs/private_key_decrypted.txt

# ─────────────────────────────────────────────────────────
# MCP Service  (optional — enable with: docker compose --profile mcp up)
# ─────────────────────────────────────────────────────────
# VITE_STORYBOOK_URL=http://localhost:6006  # override to https:// if running Storybook with TLS

MCP_ENABLED=true
MCP_PORT=3001
MCP_HOST=127.0.0.1
MCP_TRANSPORT=streamable-http
MCP_AUTO_REGISTER=true
MCP_CORE_URL=http://127.0.0.1:18789
MCP_EXPOSE_FILESYSTEM=false
# MCP_ALLOWED_PATHS=/home/secureyeoman/.secureyeoman/workspace  # required when MCP_EXPOSE_FILESYSTEM=true; comma-separated list of allowed base paths
MCP_RATE_LIMIT_PER_TOOL=30
MCP_LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────
# MCP — Kali Security Toolkit  (optional)
# Run `secureyeoman security setup` to provision the Docker container first.
# ─────────────────────────────────────────────────────────
# MCP_EXPOSE_SECURITY_TOOLS=false
# MCP_SECURITY_TOOLS_MODE=native               # native | docker-exec
# MCP_SECURITY_TOOLS_CONTAINER=kali-sy-toolkit # docker-exec mode only
# MCP_ALLOWED_TARGETS=                         # e.g. 10.10.10.0/24,ctf.example.com
# SHODAN_API_KEY=                              # optional

# ─────────────────────────────────────────────────────────
# MCP — QuickBooks Online  (optional)
# Run `secureyeoman mcp-quickbooks enable` for setup instructions.
# ─────────────────────────────────────────────────────────
# MCP_EXPOSE_QUICKBOOKS_TOOLS=false
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REALM_ID=
# QUICKBOOKS_REFRESH_TOKEN=
# QUICKBOOKS_ENVIRONMENT=sandbox               # sandbox | production

# ─────────────────────────────────────────────────────────
# OAuth Connections  (optional — needed to test social login flows)
# ─────────────────────────────────────────────────────────
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────
# Community Skills
# Docker sets COMMUNITY_REPO_PATH=/usr/share/secureyeoman/community-repo automatically.
# COMMUNITY_GIT_URL defaults to https://github.com/MacCracken/secureyeoman-community-repo
# ─────────────────────────────────────────────────────────
# COMMUNITY_REPO_PATH=/usr/share/secureyeoman/community-repo
# COMMUNITY_GIT_URL=file:///path/to/local/clone  # override for local dev; enable with: secureyeoman policy set allowCommunityGitFetch true

# ─────────────────────────────────────────────────────────
# Rate Limiting  (relaxed for local dev/testing)
# Production defaults: 5 attempts / 900000 ms (15 min)
# ─────────────────────────────────────────────────────────
SECUREYEOMAN_AUTH_LOGIN_MAX_ATTEMPTS=100
SECUREYEOMAN_AUTH_LOGIN_WINDOW_MS=60000

# ─────────────────────────────────────────────────────────
# Redis  (optional — not needed for dev)
# ─────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────
# License Enforcement (Phase 106)
# ─────────────────────────────────────────────────────────
# SECUREYEOMAN_LICENSE_ENFORCEMENT=false  # Set to true to enforce enterprise feature gates (402 for unlicensed)

# SecureYeoman — Developer Environment (Minimal)
#
# Only ADMIN_PASSWORD is required. Everything else has sensible defaults.
# For the full list of options see .env.expanded.example.
#
# Quick start:
#   cp .env.dev.example .env
#   docker compose up -d
#   npm install && npm run dev

# ─── Required ──────────────────────────────────────────────
SECUREYEOMAN_ADMIN_PASSWORD=dev-admin-password-change-in-production

# ─── Database ──────────────────────────────────────────────
# Embedded PostgreSQL auto-generates a password on first boot.
# Only set when using an external database or the docker-compose PG sidecar.
POSTGRES_PASSWORD=secureyeoman_dev

# ─── AI Providers (optional) ──────────────────────────────
# Server starts without keys; chat disabled until configured.
# Set here or add later via Administration > Secrets > AI Provider Keys.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# ─── Dev Overrides ─────────────────────────────────────────
# SECUREYEOMAN_LOG_LEVEL=debug
# SECUREYEOMAN_AUTH_LOGIN_MAX_ATTEMPTS=100     # Relaxed for dev (prod default: 5)
# SECUREYEOMAN_AUTH_LOGIN_WINDOW_MS=60000      # Relaxed for dev (prod default: 900000)

# ─── Everything else ──────────────────────────────────────
# All cryptographic keys, webhook secrets, integration API keys, MCP settings,
# TLS config, OAuth, test DB, etc. have sensible defaults.
# See .env.expanded.example for the complete reference.
